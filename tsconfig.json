{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "incremental": false,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "paths": {
      "@tipcli/sdk": ["./src/index.ts"]
    },
    "rootDir": ".",
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "scripts/**/*.ts", "recipes/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
